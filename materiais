<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inove - Materiais de Divulgação</title>
    <style>
        :root {
            --primary: #3b82f6;
            --dark-bg: #0f172a;
            --card-bg: #1e293b;
            --text-light: #f8fafc;
            --accent: #10b981;
            --drive-color: #34a853;
        }

        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background-color: var(--dark-bg);
            color: var(--text-light);
            margin: 0;
            padding: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 600px;
        }

        header {
            text-align: center;
            padding: 30px 0;
        }

        header h1 {
            margin: 0;
            font-size: 1.8rem;
            color: var(--primary);
        }

        header p {
            color: #94a3b8;
            font-size: 0.9rem;
            margin-top: 5px;
        }

        .material-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .material-card {
            background: var(--card-bg);
            border: 1px solid #334155;
            border-radius: 15px;
            padding: 18px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
            color: white;
            transition: all 0.3s ease;
        }

        .material-card:hover {
            transform: translateX(8px);
            border-color: var(--primary);
            background: #24344d;
        }

        .icon-box {
            background: rgba(52, 168, 83, 0.1);
            width: 45px;
            height: 45px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: var(--drive-color);
            flex-shrink: 0;
        }

        .info {
            flex-grow: 1;
        }

        .info h3 {
            margin: 0;
            font-size: 1rem;
            color: var(--text-light);
        }

        .info p {
            margin: 2px 0 0;
            font-size: 0.8rem;
            color: #64748b;
        }

        .arrow {
            font-size: 1.2rem;
            color: var(--primary);
            font-weight: bold;
            opacity: 0.5;
        }

        .material-card:hover .arrow {
            opacity: 1;
        }

        .alert-box {
            background: rgba(59, 130, 246, 0.1);
            border-left: 4px solid var(--primary);
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 25px;
            font-size: 0.85rem;
            color: #cbd5e1;
            text-align: center;
        }

        footer {
            margin-top: auto;
            padding: 30px 0;
            text-align: center;
            font-size: 0.8rem;
            color: #475569;
        }
    </style>
</head>
<body>

<div class="container">
