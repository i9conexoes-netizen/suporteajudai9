            <div class="arrow">→</div>
        </a>

        <a href="https://drive.google.com/drive/folders/1pBF_V1GWTr3j9t4j8w8cCBO-hP6DbAHr" target="_blank" class="material-card">
            <div class="icon-box">🖼️</div>
            <div class="info">
                <h3>Material de Divulgação 03</h3>
                <p>Imagens e Logotipos Inove</p>
            </div>
            <div class="arrow">→</div>
        </a>

        <a href="https://drive.google.com/drive/folders/16EQVavaOWKyuKee26otr-W_yIyWe9noQ" target="_blank" class="material-card">
            <div class="icon-box">📱</div>
            <div class="info">
                <h3>Material de Divulgação 04</h3>
